{
  "name": "atlas-vision-mcp",
  "version": "1.0.2",
  "description": "MCP vision bridge for text-only coding agents",
  "type": "module",
  "author": "QuangThai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/QuangThai/vision-bridge-mcp"
  },
  "bugs": {
    "url": "https://github.com/QuangThai/vision-bridge-mcp/issues"
  },
  "homepage": "https://github.com/QuangThai/vision-bridge-mcp",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "atlas-vision": "dist/cli/main.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "extensions", "hooks", "README.md"],
  "pi": {
    "extensions": ["./extensions"]
  },
  "scripts": {
    "snapshot:update": "node dist/cli/main.js eval --gate --threshold 0.8 --gate-elements --elements-threshold 0.25 --tier core --snapshot update",
    "build": "tsup",
    "prepublishOnly": "pnpm test && pnpm typecheck && pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:golden": "node dist/cli/main.js eval --gate --threshold 0.8 --gate-elements --elements-threshold 0.25 --tier core --snapshot verify",
    "eval:models": "node scripts/eval-models.mjs",
    "smoke:agents": "node scripts/smoke-agents.mjs",
    "pi:manual": "node scripts/pi-manual-test.mjs",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "keywords": ["mcp", "vision", "coding-agent", "model-context-protocol", "pi-package"],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^26.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "sharp": "^0.35.2",
    "smol-toml": "^1.7.0",
    "zod": "^3.24.1"
  }
}

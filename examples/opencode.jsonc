{
  "$schema": "https://opencode.ai/config.json",

  // ── Plugin mode (RECOMMENDED for text-only models) ──
  // Auto-intercept images before the model sees them.
  // 0 MCP calls, 0 agent decisions.
  // Copy .opencode/plugin.ts → ~/.config/opencode/plugins/atlas-vision.ts
  // "plugin": ["file:///Users/you/.config/opencode/plugins/atlas-vision.ts"],

  // ── MCP mode (on-demand only) ──
  "mcp": {
    "atlas-vision": {
      "type": "local",
      "command": ["npx", "-y", "atlas-vision-mcp"],
      "enabled": true,
      "environment": {
        "VISION_PROVIDER": "openai-compatible",
        "VISION_BASE_URL": "https://api.openai.com/v1",
        "VISION_API_KEY": "YOUR_KEY",
        "VISION_MODEL": "gpt-4o-mini",
        "ATLAS_ALLOWED_DIRS": ".",
        "ATLAS_REDACT_SECRETS": "true"
      }
    }
  }
}

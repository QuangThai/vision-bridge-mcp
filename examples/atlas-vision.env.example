# Atlas Vision — environment config
#
# The Pi extension and Codex hooks both auto-load this file — no export needed.
#
# Project-local (recommended for Pi users):
#   cp examples/atlas-vision.env.example .env
#
# Global (shared across all projects):
#   mkdir -p ~/.config/atlas-vision
#   cp examples/atlas-vision.env.example ~/.config/atlas-vision/env
#
# Explicit path override:
#   export ATLAS_VISION_ENV_FILE=/path/to/your/env

# Vision provider (Atlas reads images via this model)
VISION_PROVIDER=openai-compatible
VISION_BASE_URL=https://api.openai.com/v1
VISION_API_KEY=sk-your-vision-key
VISION_MODEL=gpt-4o-mini

# Main coding model (text-only) — models.dev provider/model id
MAIN_MODEL_PROVIDER=deepseek
MAIN_MODEL_REF=deepseek/deepseek-v4-flash

# Optional
# ATLAS_ALLOWED_DIRS=.
# ATLAS_SKIP_INTERCEPT=false
# ATLAS_FORCE_INTERCEPT=false   # keep false in production; debug only
# CURSOR_UNDERLYING_MODEL=openai/gpt-4o   # when hook ref is cursor/*
#
# Clipboard auto-detect: when Droid blocks image attachment (noImageSupport),
# the hook can read the clipboard image directly via PowerShell.
#   always  — check clipboard on every prompt (slower, most reliable)
#   smart   — check only when prompt mentions image keywords (default when set)
#   off     — never check clipboard (default when unset)
# ATLAS_CLIPBOARD_DETECT=smart
